[Unit]
Description=OpenFlow Orchestration Dashboard
After=network.target

[Service]
Type=simple
User=__USER__
WorkingDirectory=__OPENFLOW_DIR__/server
ExecStart=/usr/bin/node dist/index.js
Restart=on-failure
RestartSec=5
Environment=NODE_ENV=production
Environment=PORT=42010
StandardOutput=journal
StandardError=journal

# Graceful shutdown
KillMode=mixed
KillSignal=SIGINT
TimeoutStopSec=10

[Install]
WantedBy=multi-user.target
